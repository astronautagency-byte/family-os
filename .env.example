VITE_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
VITE_GOOGLE_MAPS_API_KEY=your-google-maps-browser-key

# Server-side only: set these as Supabase Edge Function secrets, not Vite/browser env vars.
# They are listed here as a deployment checklist only. Do not put live values in this file.
RESEND_API_KEY=re_your-resend-api-key
FAMOS_FROM_EMAIL="FamOS <invites@fam-os.app>"
WEATHERAPI_KEY=your-weatherapi-com-key
SERPAPI_KEY=your-serpapi-com-key
TICKETMASTER_API_KEY=your-ticketmaster-api-key
RECIPE_API_NINJAS_KEY=your-api-ninjas-key

# Email delivery is now handled by Resend. AWS credentials below are only
# needed for optional SMS delivery via Amazon SNS (not email).
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=ca-central-1
# AWS_SNS_SENDER_ID=FamOS

DOORDASH_DEVELOPER_ID=your-doordash-developer-id
DOORDASH_KEY_ID=your-doordash-key-id
DOORDASH_SIGNING_SECRET=your-doordash-signing-secret
